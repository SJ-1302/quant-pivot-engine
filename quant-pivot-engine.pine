open_plus_10_top = jb_day_open+10
open_plus_10_bottom = jb_day_open-10

var box1 = passlock and show_JB ? box.new(oTime, open, cTime, close, xloc=xloc.bar_time, border_style=line.style_dashed) : na
box.set_lefttop(box1, oTime, open_plus_10_top)
box.set_rightbottom(box1, cTime, open_plus_10_bottom)
box.set_bgcolor(box1, color.new(color.red,80))
