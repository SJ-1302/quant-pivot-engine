// Buy = ta.crossover(low, high_plot)
// Short = ta.crossunder(high, low_plot)

// //indicates the buy or sell signal
// plotshape(show_rect and lastDay ? Buy : na, style=shape.labeldown, location=location.abovebar, color=color.new(hiPlotColor, 0), title='Buy', text='15HBO', textcolor=color.new(color.white, 0))
// plotshape(show_rect and lastDay ? Short : na, style=shape.labelup, location=location.belowbar, color=color.new(loPlotColor, 0), title='Sell', text='15LBD', textcolor=color.new(color.white, 0))
//------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------
// VWAP

var cumVol = 0.
cumVol += nz(volume)
// if barstate.islast and cumVol == 0
    // runtime.error("No volume is provided by the data vendor.")
    
computeVWAP(src, isNewPeriod, stDevMultiplier) =>
    var float sumSrcVol = na
    var float sumVol = na
    var float sumSrcSrcVol = na

    sumSrcVol := isNewPeriod ? src * volume : src * volume + sumSrcVol[1]
    sumVol := isNewPeriod ? volume : volume + sumVol[1]
    // sumSrcSrcVol calculates the dividend of the equation that is later used to calculate the standard deviation
    sumSrcSrcVol := isNewPeriod ? volume * math.pow(src, 2) : volume * math.pow(src, 2) + sumSrcSrcVol[1]

    _vwap = sumSrcVol / sumVol
    variance = sumSrcSrcVol / sumVol - math.pow(_vwap, 2)
    variance := variance < 0 ? 0 : variance
    stDev = math.sqrt(variance)

    lowerBand = _vwap - stDev * stDevMultiplier
    upperBand = _vwap + stDev * stDevMultiplier

    [_vwap, lowerBand, upperBand]

showVWAP = input(false, title="Show VWAP?", group="VWAP Settings")
hideonDWM = input(false, title="Hide VWAP on 1D or Above", group="VWAP Settings")
var anchor = input.string(defval = "Session", title="Anchor Period",
 options=["Session", "Week", "Month", "Quarter", "Year", "Decade", "Century", "Earnings", "Dividends", "Splits"], group="VWAP Settings")
src = input(title = "Source", defval = hlc3, group="VWAP Settings")
offset = input(0, title="Offset", group="VWAP Settings")

showBands = input(false, title="Calculate Bands", group="VWAP Settings")
stdevMult = input(1.0, title="Bands Multiplier", group="VWAP Settings")

timeChange(period) =>
    ta.change(time(period))

new_earnings = request.earnings(syminfo.tickerid, earnings.actual, barmerge.gaps_on, barmerge.lookahead_on, ignore_invalid_symbol=true)
new_dividends = request.dividends(syminfo.tickerid, dividends.gross, barmerge.gaps_on, barmerge.lookahead_on, ignore_invalid_symbol=true)
new_split = request.splits(syminfo.tickerid, splits.denominator, barmerge.gaps_on, barmerge.lookahead_on, ignore_invalid_symbol=true)

isNewPeriod = switch anchor
    "Earnings" => not na(new_earnings)
    "Dividends" => not na(new_dividends)
    "Splits" => not na(new_split)
    "Session" => timeChange("D")
    "Week" => timeChange("W")
    "Month" => timeChange("M")
    "Quarter" => timeChange("3M")
    "Year" => timeChange("12M")
    "Decade" => timeChange("12M") and year % 10 == 0
    "Century" => timeChange("12M") and year % 100 == 0
    => false

isEsdAnchor = anchor == "Earnings" or anchor == "Dividends" or anchor == "Splits"
if na(src[1]) and not isEsdAnchor
    isNewPeriod := true

float vwapValue = na
float std = na
float upperBandValue = na
float lowerBandValue = na

if not (hideonDWM and timeframe.isdwm)
    [_vwap, bottom, top] = computeVWAP(src, isNewPeriod, stdevMult)
    vwapValue := _vwap
    upperBandValue := showBands ? top : na
    lowerBandValue := showBands ? bottom : na

plot(showVWAP ? vwapValue : na, title="VWAP", color=#2962FF, offset=offset)

upperBand = plot(showVWAP ? upperBandValue : na, title="Upper Band", color=color.green, offset=offset)
lowerBand = plot(showVWAP ? lowerBandValue : na, title="Lower Band", color=color.green, offset=offset)

fill(upperBand, lowerBand, title="Bands Fill", color= showBands ? color.new(color.green, 95) : na)
//----------------------------------------------------------------------------------------------------
//SuperTrend
PlotSTrend = input(title='Plot Super Trend?', defval=false, group="Super Trend Settings")
InputFactor = input.int(3, minval=1, maxval=100, title='Factor', group="Super Trend Settings")
InputLength = input.int(10, minval=1, maxval=100, title='Length', group="Super Trend Settings")
BasicUpperBand = hl2 - InputFactor * ta.atr(InputLength)
BasicLowerBand = hl2 + InputFactor * ta.atr(InputLength)
FinalUpperBand = 0.0
FinalLowerBand = 0.0
FinalUpperBand := close[1] > FinalUpperBand[1] ? math.max(BasicUpperBand, FinalUpperBand[1]) : BasicUpperBand
FinalLowerBand := close[1] < FinalLowerBand[1] ? math.min(BasicLowerBand, FinalLowerBand[1]) : BasicLowerBand
IsTrend = 0.0
IsTrend := close > FinalLowerBand[1] ? 1 : close < FinalUpperBand[1] ? -1 : nz(IsTrend[1], 1)
STrendline = IsTrend == 1 ? FinalUpperBand : FinalLowerBand
linecolor = IsTrend == 1 ? color.green : color.red
Plotline = PlotSTrend and passlock ? STrendline : na
plot(Plotline, color=linecolor, style=plot.style_line, linewidth=1, title='SuperTrend')
PlotShapeUp = ta.cross(close, STrendline) and close > STrendline
PlotShapeDown = ta.cross(STrendline, close) and close < STrendline
plotshape(PlotSTrend and passlock ? PlotShapeUp : na, 'Up Arrow', shape.triangleup, location.belowbar, color.new(color.green, 0), 0)
plotshape(PlotSTrend and passlock ? PlotShapeDown : na, 'Down Arrow', shape.triangledown, location.abovebar, color.new(color.red, 0), 0)
//----------------------------------------------------------------------------------------------------
// Historical Pivots
var DEF_COLOR = #FB8C00
var arr_time = array.new_int()
var pdh = array.new_float()
var pdl = array.new_float()
var p = array.new_float()
var tc = array.new_float()
var bc = array.new_float()
var r1 = array.new_float()
var s1 = array.new_float()
var r2 = array.new_float()
var s2 = array.new_float()
var r3 = array.new_float()
var s3 = array.new_float()
var r4 = array.new_float()
var s4 = array.new_float()
var r5 = array.new_float()
var s5 = array.new_float()
pivotX_open = float(na)
pivotX_open := nz(pivotX_open[1], open)
pivotX_high = float(na)
pivotX_high := nz(pivotX_high[1], high)
pivotX_low = float(na)
pivotX_low := nz(pivotX_low[1], low)
pivotX_prev_open = float(na)
pivotX_prev_open := nz(pivotX_prev_open[1])
pivotX_prev_high = float(na)
pivotX_prev_high := nz(pivotX_prev_high[1])
pivotX_prev_low = float(na)
pivotX_prev_low := nz(pivotX_prev_low[1])
pivotX_prev_close = float(na)
pivotX_prev_close := nz(pivotX_prev_close[1])

get_pivot_resolution() =>
    resolution = "M"
    if pivot_time_frame == AUTO
        if timeframe.isintraday
            resolution := timeframe.multiplier <= 15 ? "D" : "W"
        else if timeframe.isweekly or timeframe.ismonthly
            resolution := "12M"
    else if pivot_time_frame == DAILY
        resolution := "D"
    else if pivot_time_frame == WEEKLY
        resolution := "W"
    else if pivot_time_frame == MONTHLY
        resolution := "M"
    else if pivot_time_frame == QUARTERLY
        resolution := "3M"
    else if pivot_time_frame == YEARLY or pivot_time_frame == BIYEARLY or pivot_time_frame == TRIYEARLY or pivot_time_frame == QUINQUENNIALLY or pivot_time_frame == DECENNIALLY
        resolution := "12M"
    resolution

//----------------------------------------------------------------------------------------------------
// POC + Money Zones High + Low
var mzh = array.new_float()
var mzl = array.new_float()
var poch = array.new_float()
resolution = get_pivot_resolution()

//  ||--    Inputs:
session_timeframe = resolution
percent_of_tpo = 0.70
tf_high = high
tf_low = low
tf_close = close
//  ||--    Bars since session started:
session_bar_counter = bar_index - ta.valuewhen(ta.change(time(session_timeframe)) != 0, bar_index, 0)

session_high = tf_high
session_low = tf_low
session_range = tf_high - tf_low

session_high := nz(session_high[1], tf_high)
session_low := nz(session_low[1], tf_low)
session_range := nz(session_high - session_low, 0.0)

//      ||--    recalculate session high, low and range:
if session_bar_counter == 0
    session_high := tf_high
    session_low := tf_low
    session_range := tf_high - tf_low
    session_range
if tf_high > session_high[1]
    session_high := tf_high
    session_range := session_high - session_low
    session_range
if tf_low < session_low[1]
    session_low := tf_low
    session_range := session_high - session_low
    session_range


//  ||--    define tpo section range:
tpo_section_range = session_range / 21

//  ||--    function to get the frequency a specified range is visited:
f_frequency_of_range(_src, _upper_range, _lower_range, _length) =>
    _adjusted_length = _length < 1 ? 1 : _length
    _frequency = 0
    for _i = 0 to _adjusted_length - 1 by 1
        if _src[_i] >= _lower_range and _src[_i] <= _upper_range
            _frequency += 1
            _frequency
    _return = nz(_frequency, 0)  // _adjusted_length
    _return
//  ||--    frequency the tpo range is visited:
tpo_00 = f_frequency_of_range(tf_close, session_high, session_high - tpo_section_range * 1, session_bar_counter)
tpo_01 = f_frequency_of_range(tf_close, session_high - tpo_section_range * 1, session_high - tpo_section_range * 2, session_bar_counter)
tpo_02 = f_frequency_of_range(tf_close, session_high - tpo_section_range * 2, session_high - tpo_section_range * 3, session_bar_counter)
tpo_03 = f_frequency_of_range(tf_close, session_high - tpo_section_range * 3, session_high - tpo_section_range * 4, session_bar_counter)
tpo_04 = f_frequency_of_range(tf_close, session_high - tpo_section_range * 4, session_high - tpo_section_range * 5, session_bar_counter)
tpo_05 = f_frequency_of_range(tf_close, session_high - tpo_section_range * 5, session_high - tpo_section_range * 6, session_bar_counter)
tpo_06 = f_frequency_of_range(tf_close, session_high - tpo_section_range * 6, session_high - tpo_section_range * 7, session_bar_counter)
tpo_07 = f_frequency_of_range(tf_close, session_high - tpo_section_range * 7, session_high - tpo_section_range * 8, session_bar_counter)
tpo_08 = f_frequency_of_range(tf_close, session_high - tpo_section_range * 8, session_high - tpo_section_range * 9, session_bar_counter)
tpo_09 = f_frequency_of_range(tf_close, session_high - tpo_section_range * 9, session_high - tpo_section_range * 10, session_bar_counter)
tpo_10 = f_frequency_of_range(tf_close, session_high - tpo_section_range * 10, session_high - tpo_section_range * 11, session_bar_counter)
tpo_11 = f_frequency_of_range(tf_close, session_high - tpo_section_range * 11, session_high - tpo_section_range * 12, session_bar_counter)
tpo_12 = f_frequency_of_range(tf_close, session_high - tpo_section_range * 12, session_high - tpo_section_range * 13, session_bar_counter)
tpo_13 = f_frequency_of_range(tf_close, session_high - tpo_section_range * 13, session_high - tpo_section_range * 14, session_bar_counter)
tpo_14 = f_frequency_of_range(tf_close, session_high - tpo_section_range * 14, session_high - tpo_section_range * 15, session_bar_counter)
tpo_15 = f_frequency_of_range(tf_close, session_high - tpo_section_range * 15, session_high - tpo_section_range * 16, session_bar_counter)
tpo_16 = f_frequency_of_range(tf_close, session_high - tpo_section_range * 16, session_high - tpo_section_range * 17, session_bar_counter)
tpo_17 = f_frequency_of_range(tf_close, session_high - tpo_section_range * 17, session_high - tpo_section_range * 18, session_bar_counter)
tpo_18 = f_frequency_of_range(tf_close, session_high - tpo_section_range * 18, session_high - tpo_section_range * 19, session_bar_counter)
tpo_19 = f_frequency_of_range(tf_close, session_high - tpo_section_range * 19, session_high - tpo_section_range * 20, session_bar_counter)
tpo_20 = f_frequency_of_range(tf_close, session_high - tpo_section_range * 20, session_high - tpo_section_range * 21, session_bar_counter)
//  ||--    function to retrieve a specific tpo value
f_get_tpo_count_1(_value) =>
    _return = 0.0
    if _value == 0
        _return := tpo_00
        _return
    if _value == 1
        _return := tpo_01
        _return
    if _value == 2
        _return := tpo_02
        _return
    if _value == 3
        _return := tpo_03
        _return
    if _value == 4
        _return := tpo_04
        _return
    if _value == 5
        _return := tpo_05
        _return
    if _value == 6
        _return := tpo_06
        _return
    if _value == 7
        _return := tpo_07
        _return
    if _value == 8
        _return := tpo_08
        _return
    if _value == 9
        _return := tpo_09
        _return
    if _value == 10
        _return := tpo_10
        _return
    if _value == 11
        _return := tpo_11
        _return
    if _value == 12
        _return := tpo_12
        _return
    if _value == 13
        _return := tpo_13
        _return
    if _value == 14
        _return := tpo_14
        _return
    if _value == 15
        _return := tpo_15
        _return
    if _value == 16
        _return := tpo_16
        _return
    if _value == 17
        _return := tpo_17
        _return
    if _value == 18
        _return := tpo_18
        _return
    if _value == 19
        _return := tpo_19
        _return
    if _value == 20
        _return := tpo_20
        _return
    _return
f_get_tpo_count_2(_value) =>
    _return = 0.0
    if _value == 0
        _return := tpo_00
        _return
    if _value == 1
        _return := tpo_01
        _return
    if _value == 2
        _return := tpo_02
        _return
    if _value == 3
        _return := tpo_03
        _return
    if _value == 4
        _return := tpo_04
        _return
    if _value == 5
        _return := tpo_05
        _return
    if _value == 6
        _return := tpo_06
        _return
    if _value == 7
        _return := tpo_07
        _return
    if _value == 8
        _return := tpo_08
        _return
    if _value == 9
        _return := tpo_09
        _return
    if _value == 10
        _return := tpo_10
        _return
    if _value == 11
        _return := tpo_11
        _return
    if _value == 12
        _return := tpo_12
        _return
    if _value == 13
        _return := tpo_13
        _return
    if _value == 14
        _return := tpo_14
        _return
    if _value == 15
        _return := tpo_15
        _return
    if _value == 16
        _return := tpo_16
        _return
    if _value == 17
        _return := tpo_17
        _return
    if _value == 18
        _return := tpo_18
        _return
    if _value == 19
        _return := tpo_19
        _return
    if _value == 20
        _return := tpo_20
        _return
    _return

tpo_sum = 0.0
current_poc_position = 0.0
current_poc_value = 0.0
for _i = 0 to 20 by 1
    _get_tpo_value = f_get_tpo_count_1(_i)
    tpo_sum += _get_tpo_value
    if _get_tpo_value > current_poc_value
        current_poc_position := _i
        current_poc_value := _get_tpo_value
        current_poc_value
poc_upper = ((session_high - tpo_section_range * current_poc_position) + session_high - tpo_section_range * (current_poc_position + 1))/2

//  ||--    get value area high/low
vah_position = current_poc_position
val_position = current_poc_position
current_sum = current_poc_value

for _i = 0 to 20 by 1
    if current_sum < tpo_sum * percent_of_tpo
        vah_position := math.max(0, vah_position - 1)
        current_sum += f_get_tpo_count_2(math.round(vah_position))
        current_sum
    if current_sum < tpo_sum * percent_of_tpo
        val_position := math.min(20, val_position + 1)
        current_sum += f_get_tpo_count_2(math.round(val_position))
        current_sum

vah_value = session_high - tpo_section_range * vah_position
val_value = session_high - tpo_section_range * (val_position + 1)

vah = ta.valuewhen(session_bar_counter == 0, vah_value[1], 0)
val = ta.valuewhen(session_bar_counter == 0, val_value[1], 0)
poc_u = ta.valuewhen(session_bar_counter == 0, poc_upper[1], 0)
//----------------------------------------------------------------------------------------------------

var lines = array.new_line()
var labels = array.new_label()

draw_line(i, pivot, col) =>
    if(show_hist_pivots and passlock)
        if array.size(arr_time) > 1
            array.push(lines, line.new(array.get(arr_time, i), array.get(pivot, i), array.get(arr_time, i + 1), array.get(pivot, i), color=col, xloc=xloc.bar_time, width=line_width))

draw_label(i, y, txt, txt_color) =>
    if(show_hist_pivots and passlock)
        if (show_labels or show_prices) and not na(y)
            display_text = (show_labels ? txt : "") + (show_prices ? str.format(" ({0})", math.round_to_mintick(y)) : "")
            label_style = position_labels == "Left" ? label.style_label_right : label.style_label_left
            x = position_labels == "Left" ? array.get(arr_time, i) : array.get(arr_time, i + 1)
            array.push(labels, label.new(x = x, y=y, text=display_text, textcolor=txt_color, style=label_style, color=#00000000, xloc=xloc.bar_time))

fibonacci() =>
    pivotX_Median = (pivotX_prev_high + pivotX_prev_low + pivotX_prev_close) / 3
    pivotX_BCC = (pivotX_prev_high + pivotX_prev_low) / 2
    pivotX_TCC = pivotX_Median - pivotX_BCC + pivotX_Median
    pivot_range = pivotX_prev_high - pivotX_prev_low
    array.push(pdh, pivotX_prev_high)
    array.push(pdl, pivotX_prev_low)
    array.push(p, pivotX_Median)
    array.push(tc, pivotX_TCC)
    array.push(bc, pivotX_BCC)
    array.push(r1, pivotX_Median + 0.382 * pivot_range)
    array.push(s1, pivotX_Median - 0.382 * pivot_range)
    array.push(r2, pivotX_Median + 0.618 * pivot_range)
    array.push(s2, pivotX_Median - 0.618 * pivot_range)
    array.push(r3, pivotX_Median + 1 * pivot_range)
    array.push(s3, pivotX_Median - 1 * pivot_range)
    array.push(mzh, vah)
    array.push(mzl, val)
    array.push(poch, poc_u)

camarilla() =>
    pivotX_Median = (pivotX_prev_high + pivotX_prev_low + pivotX_prev_close) / 3
    pivotX_BCC = (pivotX_prev_high + pivotX_prev_low) / 2
    pivotX_TCC = pivotX_Median - pivotX_BCC + pivotX_Median
    pivot_range = pivotX_prev_high - pivotX_prev_low
    array.push(pdh, pivotX_prev_high)
    array.push(pdl, pivotX_prev_low)
    array.push(p, pivotX_Median)
    array.push(tc, pivotX_TCC)
    array.push(bc, pivotX_BCC)
    array.push(r1, show_camarilla_full ? pivotX_prev_close + pivot_range * 1.1 / 12.0 : na)
    array.push(s1, show_camarilla_full ? pivotX_prev_close - pivot_range * 1.1 / 12.0 : na)
    array.push(r2, show_camarilla_full ? pivotX_prev_close + pivot_range * 1.1 / 6.0 : na)
    array.push(s2, show_camarilla_full ? pivotX_prev_close - pivot_range * 1.1 / 6.0 : na)
    array.push(r3, pivotX_prev_close + pivot_range * 1.1 / 4.0)
    array.push(s3, pivotX_prev_close - pivot_range * 1.1 / 4.0)
    array.push(r4, pivotX_prev_close + pivot_range * 1.1 / 2.0)
    array.push(s4, pivotX_prev_close - pivot_range * 1.1 / 2.0)
    r5_val = pivotX_prev_high / pivotX_prev_low * pivotX_prev_close
    array.push(r5, r5_val)
    array.push(s5, 2 * pivotX_prev_close - r5_val)
    array.push(mzh, vah)
    array.push(mzl, val)
    array.push(poch, poc_u)

traditional() =>
    pivotX_Median = (pivotX_prev_high + pivotX_prev_low + pivotX_prev_close) / 3
    pivotX_BCC = (pivotX_prev_high + pivotX_prev_low) / 2
    pivotX_TCC = pivotX_Median - pivotX_BCC + pivotX_Median
    pivot_range = pivotX_prev_high - pivotX_prev_low
    array.push(pdh, pivotX_prev_high)
    array.push(pdl, pivotX_prev_low)
    array.push(p, pivotX_Median)
    array.push(tc, pivotX_TCC)
    array.push(bc, pivotX_BCC)
    array.push(r1, pivotX_Median * 2 - pivotX_prev_low)
    array.push(s1, pivotX_Median * 2 - pivotX_prev_high)
    array.push(r2, pivotX_Median + 1 * (pivotX_prev_high - pivotX_prev_low))
    array.push(s2, pivotX_Median - 1 * (pivotX_prev_high - pivotX_prev_low))
    array.push(r3, pivotX_Median * 2 + (pivotX_prev_high - 2 * pivotX_prev_low))
    array.push(s3, pivotX_Median * 2 - (2 * pivotX_prev_high - pivotX_prev_low))
    array.push(r4, pivotX_Median * 3 + (pivotX_prev_high - 3 * pivotX_prev_low))
    array.push(s4, pivotX_Median * 3 - (3 * pivotX_prev_high - pivotX_prev_low))
    array.push(r5, pivotX_Median * 4 + (pivotX_prev_high - 4 * pivotX_prev_low))
    array.push(s5, pivotX_Median * 4 - (4 * pivotX_prev_high - pivotX_prev_low))
    array.push(mzh, vah)
    array.push(mzl, val)
    array.push(poch, poc_u)

pivotboss() =>
    pivotX_Median = (pivotX_prev_high + pivotX_prev_low + pivotX_prev_close) / 3
    pivotX_BCC = (pivotX_prev_high + pivotX_prev_low) / 2
    pivotX_TCC = pivotX_Median - pivotX_BCC + pivotX_Median
    pivot_range = pivotX_prev_high - pivotX_prev_low
    array.push(pdh, pivotX_prev_high)
    array.push(pdl, pivotX_prev_low)
    array.push(p, pivotX_Median)
    array.push(tc, pivotX_TCC)
    array.push(bc, pivotX_BCC)
    array.push(r1,pivotX_prev_high + (pivotX_prev_high - pivotX_prev_low) * 0.25)
    array.push(r2,pivotX_prev_high + (pivotX_prev_high - pivotX_prev_low) * 0.50)
    array.push(r3,pivotX_prev_high + (pivotX_prev_high - pivotX_prev_low) * 0.75)
    array.push(r4,pivotX_prev_high + pivotX_prev_high - pivotX_prev_low)
    array.push(s1,pivotX_prev_low - (pivotX_prev_high - pivotX_prev_low) * 0.25)
    array.push(s2,pivotX_prev_low - (pivotX_prev_high - pivotX_prev_low) * 0.50)
    array.push(s3,pivotX_prev_low - (pivotX_prev_high - pivotX_prev_low) * 0.75)
    array.push(s4,pivotX_prev_low - (pivotX_prev_high - pivotX_prev_low))
    array.push(mzh, vah)
    array.push(mzl, val)
    array.push(poch, poc_u)

vpr() =>
    pivotX_Median = (pivotX_prev_high + pivotX_prev_low + pivotX_prev_close) / 3
    pivotX_BCC = (pivotX_prev_high + pivotX_prev_low) / 2
    pivotX_TCC = pivotX_Median - pivotX_BCC + pivotX_Median
    pivot_range = pivotX_prev_high - pivotX_prev_low
    array.push(tc, pivotX_TCC)
    array.push(bc, pivotX_BCC)
    array.push(pdh, pivotX_prev_high)
    array.push(pdl, pivotX_prev_low)
    array.push(mzh, vah)
    array.push(mzl, val)
    array.push(poch, poc_u)
    array.push(s1,(pivotX_prev_open + pivotX_prev_high) / 2)
    array.push(r2,(pivotX_prev_open + pivotX_prev_close) / 2)
    array.push(s2,(pivotX_prev_open + pivotX_prev_low) / 2)
    array.push(r3,(pivotX_prev_high + pivotX_prev_low) / 2)
    array.push(s3,(pivotX_prev_high + pivotX_prev_close) / 2)
    array.push(r4,(pivotX_prev_low + pivotX_prev_close) / 2)
    array.push(p,(pivotX_prev_high + pivotX_prev_low + pivotX_prev_close) / 3)
    array.push(r5,(pivotX_prev_open + pivotX_prev_low + pivotX_prev_close) / 3)
    array.push(s5,(pivotX_prev_open + pivotX_prev_high + pivotX_prev_low) / 3)
    array.push(s4, (pivotX_prev_open + pivotX_prev_high + pivotX_prev_close) / 3)
    array.push(r1,(pivotX_prev_high + pivotX_prev_low + pivotX_prev_close + pivotX_prev_open) / 4)

calc_pivot() =>
    if kind == FIBONACCI
        fibonacci()
    else if kind == CAMARILLA
        camarilla()
    else if kind == TRADITIONAL
        traditional()
    else if kind == PIVOTBOSS
        pivotboss()
    else if kind == VPR
        vpr()

//resolution = get_pivot_resolution()

SIMPLE_DIVISOR = -1
custom_years_divisor = switch pivot_time_frame
    BIYEARLY => 2
    TRIYEARLY => 3
    QUINQUENNIALLY => 5
    DECENNIALLY => 10
    => SIMPLE_DIVISOR

calc_high(prev, curr) =>
    if na(prev) or na(curr)
        nz(prev, nz(curr, na))
    else
        math.max(prev, curr)
    
calc_low(prev, curr) =>
    if not na(prev) and not na(curr)
        math.min(prev, curr)
    else
        nz(prev, nz(curr, na))

calc_OHLC_for_pivot(custom_years_divisor) =>
    if custom_years_divisor == SIMPLE_DIVISOR 
        [open, high, low, close, open[1], high[1], low[1], close[1], time[1], time_close]
    else
        var prev_sec_open = float(na)
        var prev_sec_high = float(na)
        var prev_sec_low = float(na)
        var prev_sec_close = float(na)
        var prev_sec_time = int(na)
        var curr_sec_open = float(na)
        var curr_sec_high = float(na)
        var curr_sec_low = float(na)
        var curr_sec_close = float(na)
        if year(time_close) % custom_years_divisor == 0
            curr_sec_open := open
            curr_sec_high := high
            curr_sec_low := low
            curr_sec_close := close
            prev_sec_high := high[1]
            prev_sec_low := low[1]
            prev_sec_close := close[1]
            prev_sec_time := time[1]
            for i = 2 to custom_years_divisor
                prev_sec_open :=  nz(open[i], prev_sec_open)
                prev_sec_high := calc_high(prev_sec_high, high[i])
                prev_sec_low := calc_low(prev_sec_low, low[i])
                prev_sec_time := nz(time[i], prev_sec_time)
        [curr_sec_open, curr_sec_high, curr_sec_low, curr_sec_close, prev_sec_open, prev_sec_high, prev_sec_low, prev_sec_close, prev_sec_time, time_close]

[sec_open, sec_high, sec_low, sec_close, prev_sec_open, prev_sec_high, prev_sec_low, prev_sec_close, prev_sec_time, sec_time] = request.security(syminfo.tickerid, resolution, calc_OHLC_for_pivot(custom_years_divisor), lookahead = barmerge.lookahead_on)
sec_open_gaps_on = request.security(syminfo.tickerid, resolution, open, gaps = barmerge.gaps_on, lookahead = barmerge.lookahead_on)

is_change_years = custom_years_divisor > 0 and ta.change(time(resolution)) and year(time_close) % custom_years_divisor == 0

var is_change = false
var uses_current_bar = timeframe.isintraday and kind == WOODIE
var change_time = int(na)
is_time_change = (ta.change(time(resolution)) and custom_years_divisor == SIMPLE_DIVISOR) or is_change_years
if is_time_change
    change_time := time

var start_time = time
var was_last_premarket = false
var start_calculate_in_premarket = false

is_last_premarket = barstate.islast and session.ispremarket and time_close > sec_time and not was_last_premarket

if is_last_premarket
    was_last_premarket := true
    start_calculate_in_premarket := true
if session.ismarket
    was_last_premarket := false
    
without_time_change = barstate.islast and array.size(arr_time) == 0
is_can_calc_pivot = (not uses_current_bar and is_time_change and session.ismarket) or (ta.change(sec_open) and not start_calculate_in_premarket) or is_last_premarket or (uses_current_bar and not na(sec_open_gaps_on)) or without_time_change
enough_bars_for_calculate = prev_sec_time >= start_time or is_daily_based

if is_can_calc_pivot and enough_bars_for_calculate 
    if array.size(arr_time) == 0 and is_daily_based
        pivotX_prev_open := prev_sec_open[1]
        pivotX_prev_high := prev_sec_high[1]
        pivotX_prev_low := prev_sec_low[1]
        pivotX_prev_close := prev_sec_close[1]
        pivotX_open := sec_open[1]
        pivotX_high := sec_high[1]
        pivotX_low := sec_low[1]
        array.push(arr_time, start_time)
        calc_pivot()
    
    if is_daily_based
        if is_last_premarket
            pivotX_prev_open := sec_open
            pivotX_prev_high := sec_high
            pivotX_prev_low := sec_low
            pivotX_prev_close := sec_close
            pivotX_open := open
            pivotX_high := high
            pivotX_low := low
        else
            pivotX_prev_open := prev_sec_open
            pivotX_prev_high := prev_sec_high
            pivotX_prev_low := prev_sec_low
            pivotX_prev_close := prev_sec_close
            pivotX_open := sec_open
            pivotX_high := sec_high
            pivotX_low := sec_low
    else
        pivotX_prev_high := pivotX_high
        pivotX_prev_low := pivotX_low
        pivotX_prev_open := pivotX_open
        pivotX_prev_close := close[1]
        pivotX_open := open
        pivotX_high := high
        pivotX_low := low

//    if show_tomorrow_cpr_pivots
//        pivotX_prev_high := th_d
//        pivotX_prev_low := tl_d
//        pivotX_prev_close := tc_d

    if barstate.islast and not is_change and array.size(arr_time) > 0 and not without_time_change
        array.set(arr_time, array.size(arr_time) - 1, change_time)
    else if without_time_change
        array.push(arr_time, start_time)
    else
        array.push(arr_time, nz(change_time, time))

    calc_pivot()

    if array.size(arr_time) > look_back
        if array.size(arr_time) > 0
            array.shift(arr_time)
        if array.size(p) > 0 and show_hist_pivots_pivot_only
            array.shift(p)
        if array.size(tc) > 0 and show_hist_pivots_CPR
            array.shift(tc)
            array.shift(bc)
        if array.size(r1) > 0 and show_hist_pivots_rs
            array.shift(r1)
        if array.size(s1) > 0 and show_hist_pivots_rs
            array.shift(s1)
        if array.size(r2) > 0 and show_hist_pivots_rs
            array.shift(r2)
        if array.size(s2) > 0 and show_hist_pivots_rs
            array.shift(s2)
        if array.size(r3) > 0 and show_hist_pivots_rs
            array.shift(r3)
        if array.size(s3) > 0 and show_hist_pivots_rs
            array.shift(s3)
        if array.size(r4) > 0 and show_hist_pivots_rs
            array.shift(r4)
        if array.size(s4) > 0 and show_hist_pivots_rs
            array.shift(s4)
        if array.size(r5) > 0 and show_hist_pivots_rs
            array.shift(r5)
        if array.size(s5) > 0 and show_hist_pivots_rs
            array.shift(s5)
        if array.size(pdh) > 0 and show_hist_pdhpdl
            array.shift(pdh)
        if array.size(pdl) > 0 and show_hist_pdhpdl
            array.shift(pdl)
        if array.size(poch) > 0 and show_poc
            array.shift(poch)
        if array.size(mzh) > 0 and show_money_zones
            array.shift(mzh)
        if array.size(mzl) > 0 and show_money_zones
            array.shift(mzl)
    is_change := true
else if not is_daily_based
    pivotX_high := math.max(pivotX_high, high)
    pivotX_low := math.min(pivotX_low, low)

if barstate.islast and not is_daily_based and array.size(arr_time) == 0 
    runtime.error("Not enough intraday data to calculate Pivot Points. Lower the Pivots Timeframe or turn on the 'Use Daily-based Values' option in the indicator settings.")

if barstate.islast and array.size(arr_time) > 0 and is_change
    is_change := false
    if custom_years_divisor > 0
        last_pivot_time = array.get(arr_time, array.size(arr_time) - 1)
        pivot_timeframe = str.tostring(12 * custom_years_divisor) + "M"
        estimate_pivot_time = last_pivot_time + timeframe.in_seconds(pivot_timeframe) * 1000
        array.push(arr_time, estimate_pivot_time)
    else
        array.push(arr_time, time_close(resolution))

    for i = 0 to array.size(lines) - 1
        if array.size(lines) > 0
            line.delete(array.shift(lines))
        if array.size(labels) > 0
            label.delete(array.shift(labels))

    var x = 0
    if (show_hist_pivots_only_today)
        x := array.size(arr_time) - 2
    else
        x := 0        

    for i = x to array.size(arr_time) - 2
        if array.size(p) > 0 and show_hist_pivots_pivot_only
            draw_line(i, p, color.new(color.blue, 0))
            draw_label(i, array.get(p, i), "P", color.new(color.blue, 0))
        if array.size(p) > 0 and show_hist_pivots_CPR
            draw_line(i, tc, color.new(color.blue, 0))
            draw_line(i, bc, color.new(color.blue, 0))
            draw_label(i, array.get(bc, i), "BC", color.new(color.blue, 0))
            draw_label(i, array.get(tc, i), "TC", color.new(color.blue, 0))
        if array.size(r1) > 0 and show_hist_pivots_rs
            draw_line(i, r1, color.red)
            draw_label(i, array.get(r1, i), "R1", color.red)
        if array.size(s1) > 0 and show_hist_pivots_rs
            draw_line(i, s1, color.lime)
            draw_label(i, array.get(s1, i), "S1", color.lime)
        if array.size(r2) > 0 and show_hist_pivots_rs
            draw_line(i, r2, color.red)
            draw_label(i, array.get(r2, i), "R2", color.red)
        if array.size(s2) > 0 and show_hist_pivots_rs
            draw_line(i, s2, color.lime)
            draw_label(i, array.get(s2, i), "S2", color.lime)
        if array.size(r3) > 0 and show_hist_pivots_rs
            draw_line(i, r3, color.red)
            draw_label(i, array.get(r3, i), (kind == CAMARILLA)? "R3 - Sell Reversal" : "R3", color.red)
        if array.size(s3) > 0 and show_hist_pivots_rs
            draw_line(i, s3, color.lime)
            draw_label(i, array.get(s3, i), (kind == CAMARILLA)? "S3 - Buy Reversal" : "S3", color.lime)
        if array.size(r4) > 0 and show_hist_pivots_rs
            draw_line(i, r4, color.red)
            draw_label(i, array.get(r4, i), (kind == CAMARILLA)? "R4 - Bullish Breakout" : "R4", color.red)
        if array.size(s4) > 0 and show_hist_pivots_rs
            draw_line(i, s4, color.lime)
            draw_label(i, array.get(s4, i), (kind == CAMARILLA)? "S4 - Bearish Breakout" : "S4", color.lime)
        if array.size(r5) > 0 and show_hist_pivots_rs
            draw_line(i, r5, color.red)
            draw_label(i, array.get(r5, i), (kind == CAMARILLA)? "R5 - Breakout Target" : "R5", color.red)
        if array.size(s5) > 0 and show_hist_pivots_rs
            draw_line(i, s5, color.lime)
            draw_label(i, array.get(s5, i), (kind == CAMARILLA)? "S5 - Breakout Target" : "S5", color.lime)
        if array.size(pdh) > 0 and show_hist_pdhpdl
            draw_line(i, pdh, pdhpdl_color)
            draw_label(i, array.get(pdh, i), "PDH", pdhpdl_color)
        if array.size(pdl) > 0 and show_hist_pdhpdl
            draw_line(i, pdl, pdhpdl_color)
            draw_label(i, array.get(pdl, i), "PDL", pdhpdl_color)
        if array.size(pdl) > 0 and show_poc
            draw_line(i, poch, poc_color)
            draw_label(i, array.get(poch, i), "POC", poc_color)
        if array.size(pdl) > 0 and show_money_zones
            draw_line(i, mzh, moneyZone_color)
            draw_label(i, array.get(mzh, i), "Money Zone High", moneyZone_color)
            draw_line(i, mzl, moneyZone_color)
            draw_label(i, array.get(mzl, i), "Money Zone Low", moneyZone_color)
//----------------------------------------------------------------------------------------------------
// Extend tomorrow CPR
time_y = year(time)
time_m = month(time)
time_d = dayofmonth(time)
time_3m = month(time)
time_3m2 = year(time)

if time_m == 12
    time_y := time_y + 1
    time_m := 1
    time_m
else
    time_m += 1
    time_m

if time_m == 1 or time_m == 2 or time_m == 3
    time_3m := 4
if time_m == 4 or time_m == 5 or time_m == 6
    time_3m := 7
if time_m == 7 or time_m == 8 or time_m == 9
    time_3m := 10
if time_m == 10 or time_m == 11 or time_m == 12
    time_3m := 1
    time_3m2 := time_y + 1


next_month = timestamp(time_y, time_m, 1, 0, 0)
next_quarter = timestamp(time_3m2, time_3m, 1, 0, 0)
next_quarter2 = timestamp(time_3m2, time_3m + 3, 1, 0, 0)
next_year = timestamp(time_y + 1, 1, 1, 0, 0)
next_year2 = timestamp(time_y + 1, 12, 1, 0, 0)


var tom_start = 0
var tom_end = 0

if resolution == 'M'
    tom_start := next_month
    tom_end := tom_start + 60000 * 60 * 24 * 30
    tom_end

if resolution == '3M'
    tom_start := next_quarter
    tom_end := next_quarter2
    tom_end

if resolution == '12M'
    tom_start := next_year
    tom_end := next_year2
    tom_end

if resolution == 'W'
    if time(timeframe.period, '0000-1200:2') and not time(timeframe.period, '0000-1200:2')[1]
        tom_start := time + 1000 * 60 * 60 * 24 * 7
        tom_end := tom_start + 1000 * 60 * 60 * 24 * 7
        tom_end

IsWeekend(_date) =>
    dayofweek(_date) == 7 or dayofweek(_date) == 1
// Skip Weekend
SkipWeekend(_date) =>
    if sat_sun
        _d = dayofweek(_date)
        _mul = _d == 6 ? 3 : _d == 7 ? 2 : 1
        
        _date + (_mul * 86400000)
    else
        _date + 86400000

        
y = year(timenow)
m = month(timenow)
d = dayofmonth(timenow)

// Start & End time for Today's CPR
newStart = timestamp(y, m, d, 09, 15)
if resolution == 'D'
    if time(timeframe.period, '0000-1200:1234567') and not time(timeframe.period, '0000-1200:1234567')[1]
        tom_start := sat_sun ? SkipWeekend(newStart) : time + ((1000 * 60 * 60 * 24))
        tom_end := tom_start + 1000 * 60 * 60 * 24
        tom_end


//Label func()
fib_label(x_, y_, text_, textcolor_) =>
    if str.length(str.tostring(math.round(y_))) >= 2
        factor = math.pow(10, 2)
        numberR = int(y_ * factor) / factor
        label.new(x_, y_, text=text_ + ' (' + str.tostring(numberR) + ')', xloc=xloc.bar_time, textcolor=textcolor_, color=color.new(color.black, 100), style=label.style_label_lower_right)
    else
        label.new(x_, y_, text=text_ + ' (' + str.tostring(y_) + ')', xloc=xloc.bar_time, textcolor=textcolor_, color=color.new(color.black, 100), style=label.style_label_lower_right)

tomorrowHigh = request.security(syminfo.tickerid, resolution, high, barmerge.gaps_off, barmerge.lookahead_on)
tomorrowCLose = request.security(syminfo.tickerid, resolution, close, barmerge.gaps_off, barmerge.lookahead_on)
tomorrowLow = request.security(syminfo.tickerid, resolution, low, barmerge.gaps_off, barmerge.lookahead_on)

// Pivot Range
tomorrowPivot = (tomorrowHigh + tomorrowLow + tomorrowCLose) / 3
tomorrowBC = (tomorrowHigh + tomorrowLow) / 2
tomorrowTC = tomorrowPivot - tomorrowBC + tomorrowPivot

// Tomorrow Traditional
tR3 = tomorrowHigh + 2 * (tomorrowPivot - tomorrowLow)
tR2 = tomorrowPivot + tomorrowHigh - tomorrowLow
tR1 = tomorrowPivot * 2 - tomorrowLow
tR4 = tR3 + (tR2 - tR1)
tS1 = tomorrowPivot * 2 - tomorrowHigh
tS2 = tomorrowPivot - (tomorrowHigh - tomorrowLow)
tS3 = tomorrowLow - 2 * (tomorrowHigh - tomorrowPivot)
tS4 = tS3 - (tS1 - tS2)

// Tomorrow Fib Pivots
tR1fib= tomorrowPivot + 0.382 * (tomorrowHigh - tomorrowLow)
tS1fib= tomorrowPivot - 0.382 * (tomorrowHigh - tomorrowLow)
tR2fib= tomorrowPivot + 0.618 * (tomorrowHigh - tomorrowLow)
tS2fib= tomorrowPivot - 0.618 * (tomorrowHigh - tomorrowLow)
tR3fib= tomorrowPivot + 1 * (tomorrowHigh - tomorrowLow)
tS3fib= tomorrowPivot - 1 * (tomorrowHigh - tomorrowLow)
tR4fib= tomorrowPivot + 1.272 * (tomorrowHigh - tomorrowLow)
tS4fib= tomorrowPivot - 1.272 * (tomorrowHigh - tomorrowLow)

// Tomorrow Camarilla
tH3 = tomorrowCLose + (tomorrowHigh - tomorrowLow) * (1.1 / 4)
tH4 = tomorrowCLose + (tomorrowHigh - tomorrowLow) * (1.1 / 2)
tH5 = tomorrowHigh / tomorrowLow * tomorrowCLose
tL3 = tomorrowCLose - (tomorrowHigh - tomorrowLow) * (1.1 / 4)
tL4 = tomorrowCLose - (tomorrowHigh - tomorrowLow) * (1.1 / 2)
tL5 = tomorrowCLose - (tH5 - tomorrowCLose)
tH1 = tomorrowCLose + (tomorrowHigh - tomorrowLow) * (1.1 / 12)
tH2 = tomorrowCLose + (tomorrowHigh - tomorrowLow) * (1.1 / 6)
tL1 = tomorrowCLose - (tomorrowHigh - tomorrowLow) * (1.1 / 12)
tL2 = tomorrowCLose - (tomorrowHigh - tomorrowLow) * (1.1 / 6)

//Tomorrow PivotBoss
pivotBossR1 = tomorrowHigh + (tomorrowHigh - tomorrowLow) * 0.25
pivotBossR2 = tomorrowHigh + (tomorrowHigh - tomorrowLow) * 0.50
pivotBossR3 = tomorrowHigh + (tomorrowHigh - tomorrowLow) * 0.75
pivotBossR4 = tomorrowHigh + tomorrowHigh - tomorrowLow
pivotBossS1 = tomorrowLow - (tomorrowHigh - tomorrowLow) * 0.25
pivotBossS2 = tomorrowLow - (tomorrowHigh - tomorrowLow) * 0.50
pivotBossS3 = tomorrowLow - (tomorrowHigh - tomorrowLow) * 0.75
pivotBossS4 = tomorrowLow - (tomorrowHigh - tomorrowLow)

if show_tomorrow_cpr_pivots and (kind == PIVOTBOSS) and passlock and show_hist_pivots_rs
    pivboss_t_r4 = line.new(tom_start, (pivotBossR1), tom_end, (pivotBossR1), xloc.bar_time, color=color.red, width=line_width)
    line.delete(pivboss_t_r4[1])
    pivboss_t_r3 = line.new(tom_start, (pivotBossR2), tom_end, (pivotBossR2), xloc.bar_time, color=color.red, width=line_width)
    line.delete(pivboss_t_r3[1])
    pivboss_t_r2 = line.new(tom_start, (pivotBossR3), tom_end, (pivotBossR3), xloc.bar_time, color=color.red, width=line_width)
    line.delete(pivboss_t_r2[1])
    pivboss_t_r1 = line.new(tom_start, (pivotBossR4), tom_end, (pivotBossR4), xloc.bar_time, color=color.red, width=line_width)
    line.delete(pivboss_t_r1[1])
    pivboss_t_s1 = line.new(tom_start, (pivotBossS1), tom_end, (pivotBossS1), xloc.bar_time, color=color.lime, width=line_width)
    line.delete(pivboss_t_s1[1])
    pivboss_t_s2 = line.new(tom_start, (pivotBossS2), tom_end, (pivotBossS2), xloc.bar_time, color=color.lime, width=line_width)
    line.delete(pivboss_t_s2[1])
    pivboss_t_s3 = line.new(tom_start, (pivotBossS3), tom_end, (pivotBossS3), xloc.bar_time, color=color.lime, width=line_width)
    line.delete(pivboss_t_s3[1])
    pivboss_t_s4 = line.new(tom_start, (pivotBossS4), tom_end, (pivotBossS4), xloc.bar_time, color=color.lime, width=line_width)
    line.delete(pivboss_t_s4[1])

if show_tomorrow_cpr_pivots and (kind == PIVOTBOSS) and (show_labels or show_prices) and passlock and show_hist_pivots_rs
    l_pivboss_t_r4 = label.new(tom_end, (pivotBossR4), text =  (show_labels ? 'R4 ' : "") + (show_prices ? "("+str.tostring(tR4fib, format.mintick)+")" : ""), xloc=xloc.bar_time, textcolor=color.red, color=color.new(color.black, 100), style=label.style_label_left)
    label.delete(l_pivboss_t_r4[1])
    l_pivboss_t_r3 = label.new(tom_end, (pivotBossR3), text =  (show_labels ? 'R3 ' : "") + (show_prices ? "("+str.tostring(tR3fib, format.mintick)+")" : ""), xloc=xloc.bar_time, textcolor=color.red, color=color.new(color.black, 100), style=label.style_label_left)
    label.delete(l_pivboss_t_r3[1])
    l_pivboss_t_r2 = label.new(tom_end, (pivotBossR2), text =  (show_labels ? 'R2 ' : "") + (show_prices ? "("+str.tostring(tR2fib, format.mintick)+")" : ""), xloc=xloc.bar_time, textcolor=color.red, color=color.new(color.black, 100), style=label.style_label_left)
    label.delete(l_pivboss_t_r2[1])
    l_pivboss_t_r1 = label.new(tom_end, (pivotBossR1), text =  (show_labels ? 'R1 ' : "") + (show_prices ? "("+str.tostring(tR1fib, format.mintick)+")" : ""), xloc=xloc.bar_time, textcolor=color.red, color=color.new(color.black, 100), style=label.style_label_left)
    label.delete(l_pivboss_t_r1[1])
    l_pivboss_t_s1 = label.new(tom_end, (pivotBossS1), text =  (show_labels ? 'S1 ' : "") + (show_prices ? "("+str.tostring(tS1fib, format.mintick)+")" : ""), xloc=xloc.bar_time, textcolor=color.lime, color=color.new(color.black, 100), style=label.style_label_left)
    label.delete(l_pivboss_t_s1[1])
    l_pivboss_t_s2 = label.new(tom_end, (pivotBossS2), text =  (show_labels ? 'S2 ' : "") + (show_prices ? "("+str.tostring(tS2fib, format.mintick)+")" : ""), xloc=xloc.bar_time, textcolor=color.lime, color=color.new(color.black, 100), style=label.style_label_left)
    label.delete(l_pivboss_t_s2[1])
    l_pivboss_t_s3 = label.new(tom_end, (pivotBossS3), text =  (show_labels ? 'S3 ' : "") + (show_prices ? "("+str.tostring(tS3fib, format.mintick)+")" : ""), xloc=xloc.bar_time, textcolor=color.lime, color=color.new(color.black, 100), style=label.style_label_left)
    label.delete(l_pivboss_t_s3[1])
    l_pivboss_t_s4 = label.new(tom_end, (pivotBossS4), text =  (show_labels ? 'S4 ' : "") + (show_prices ? "("+str.tostring(tS4fib, format.mintick)+")" : ""), xloc=xloc.bar_time, textcolor=color.lime, color=color.new(color.black, 100), style=label.style_label_left)
    label.delete(l_pivboss_t_s4[1])

if show_tomorrow_cpr_pivots and passlock and show_hist_pivots_pivot_only
    _t_tc = line.new(tom_start, tomorrowTC, tom_end, tomorrowTC, xloc.bar_time, color=color.blue, width=line_width)
    line.delete(_t_tc[1])
    _t_p = line.new(tom_start, (tomorrowPivot), tom_end, (tomorrowPivot), xloc.bar_time, color=color.blue, width=line_width)
    line.delete(_t_p[1])
    _t_bc = line.new(tom_start, tomorrowBC, tom_end, tomorrowBC, xloc.bar_time, color=color.blue, width=line_width)
    line.delete(_t_bc[1])

if show_tomorrow_cpr_pivots and passlock and show_hist_pdhpdl
    _pdh = line.new(tom_start, (tomorrowHigh), tom_end, (tomorrowHigh), xloc.bar_time, color=color.white, width=line_width)
    line.delete(_pdh[1])
    _pdl = line.new(tom_start, (tomorrowLow), tom_end, (tomorrowLow), xloc.bar_time, color=color.white, width=line_width)
    line.delete(_pdl[1])    

if show_tomorrow_cpr_pivots and (show_labels or show_prices) and passlock and show_hist_pivots_pivot_only
    l_t_tc = label.new(tom_end, tomorrowTC, text =  (show_labels ? 'tTC ' : "") + (show_prices ? "("+str.tostring(tomorrowTC, format.mintick)+")" : ""), xloc=xloc.bar_time, textcolor=color.blue, color=color.new(color.black, 100), style=label.style_label_left)
    label.delete(l_t_tc[1])
    l_t_p = label.new(tom_end, (tomorrowPivot), text =  (show_labels ? 'P ' : "") + (show_prices ? "("+str.tostring(tomorrowPivot, format.mintick)+")" : ""), xloc=xloc.bar_time, textcolor=color.blue, color=color.new(color.black, 100), style=label.style_label_left)
