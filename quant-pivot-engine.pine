// Algorithm: Quant Pivot Engine
// Description: Full-featured pivot engine supporting Fibonacci, Camarilla, Traditional, PivotBoss, and VPR pivot types.
//              Includes Weekly/Monthly CPR, Dynamic Historical Pivots, Point of Control (POC), Money Zones (VAH/VAL),
//              VWAP with bands, SuperTrend, Hull MA Trend, Bollinger Bands/Donchian/Envelope channels,
//              Volume-based candle coloring, extra Fibonacci pivot levels, and Weekly Camarilla levels.
//              Tomorrow CPR lines for next session planning are also supported.

//@version=5
indicator('Quant Pivot Engine', overlay=true, max_lines_count=500, max_bars_back=4900, max_boxes_count=500, format=format.price, precision=2)

//-------------------------------------------------------------------------------------------
// Password Check
password = input.string(title="Please Enter Password", defval="impetus")
var passlock = false
if str.tostring(password) == "impetus"
    passlock := true


// INTERMEDIATE STEP : CPR : Cont'd in Line 1943
showWeeklyCam = input(false   , "Show Weekly Camarilla Levels?", inline="Show Cam Levels?",group="WEEKLY / MONTHLY CPR")
weeklyCamOffset = input.int(title='Camarilla Label offset', defval=-90, step=1, group="WEEKLY / MONTHLY CPR")

show_CPR_tomorrow = input(false   , "Show Weekly CPR Levels?", inline="Show Tomorrow CPR Levels?",group="WEEKLY / MONTHLY CPR")
show_cpr_monthly = input(false   , "Show Monthly CPR Levels?", inline="Show Tomorrow CPR Levels?",group="WEEKLY / MONTHLY CPR")
cprLabelOffset = input.int(title='CPR Label offset', defval=90, step=1,group="WEEKLY / MONTHLY CPR")

// Calculate Tomorrow's CPR
// Get High, Low and Close

th_d = request.security(syminfo.tickerid, 'M', high[1], barmerge.gaps_off, barmerge.lookahead_on)
tl_d = request.security(syminfo.tickerid, 'M', low[1], barmerge.gaps_off, barmerge.lookahead_on)
tc_d = request.security(syminfo.tickerid, 'M', close[1], barmerge.gaps_off, barmerge.lookahead_on)

th_d_w = request.security(syminfo.tickerid, 'W', high[1], barmerge.gaps_off, barmerge.lookahead_on)
tl_d_w = request.security(syminfo.tickerid, 'W', low[1], barmerge.gaps_off, barmerge.lookahead_on)
tc_d_w = request.security(syminfo.tickerid, 'W', close[1], barmerge.gaps_off, barmerge.lookahead_on)
//------------------------------------------------------------------------------
// INTERMEDIATE STEP : Historical Pivot
AUTO = "Auto"
DAILY = "Daily"
WEEKLY = "Weekly"
MONTHLY = "Monthly"
QUARTERLY = "Quarterly"
YEARLY = "Yearly"
BIYEARLY = "Biyearly"
TRIYEARLY = "Triyearly"
QUINQUENNIALLY = "Quinquennially"
DECENNIALLY = "Decennially"
FIBONACCI = "Fibonacci"
CAMARILLA = "Camarilla"
TRADITIONAL = "Traditional"
WOODIE = "Woodie"
PIVOTBOSS = "PivotBoss"
VPR = "VPR"
show_hist_pivots = input.bool(title="Show Pivots?", defval=true, group="Dynamic Pivots")
show_hist_pivots_only_today = input.bool(title="Hide Historical Pivots?", defval=true, group="Dynamic Pivots")
show_hist_pivots_pivot_only = input.bool(title="Show Central Pivot?", defval=true, group="Dynamic Pivots")
show_hist_pivots_CPR = input.bool(title="Show TC/BC for CPR?", defval=true, group="Dynamic Pivots")
show_hist_pivots_rs = input.bool(title="Show Pivot R/S?", defval=true, group="Dynamic Pivots")
show_camarilla_full = input.bool(title="Show Full Camarilla Levels?", defval=true, group="Dynamic Pivots")
show_hist_pdhpdl = input.bool(title="Show PDH/PDL Levels?", defval=true, group="Dynamic Pivots", inline="PdhPdl")
pdhpdl_color  = input(color.white, ""     , inline="PdhPdl",group="Dynamic Pivots")
show_poc = input.bool(title="Show Point of Control?", defval=true, group="Dynamic Pivots", inline="POC")
poc_color  = input(color.white, ""     , inline="POC",group="Dynamic Pivots")
show_money_zones = input.bool(title="Show Money Zones?", defval=true, group="Dynamic Pivots", inline="moneyZone")
moneyZone_color  = input(color.white, ""     , inline="moneyZone",group="Dynamic Pivots")
show_labels = input.bool(title="Show Pivot Labels?", defval=true, group="Dynamic Pivots")
show_prices = input.bool(title="Show Pivot Prices?", defval=true, group="Dynamic Pivots")
show_tomorrow_cpr_pivots = input.bool(title="Show Tomorrow CPR + Pivots?", defval=false, group="Dynamic Pivots")
sat_sun = input.bool(false, title  = 'Saturday and sunday are holidays', group = 'Dynamic Pivots', tooltip = 'Turn on during sunday and saturday only')
is_daily_based = input.bool(title="Use Daily-based Values", defval=true, tooltip="When this option is unchecked, Pivot Points will use intraday data while calculating on intraday charts. If Extended Hours are displayed on the chart, they will be taken into account during the pivot level calculation. If intraday OHLC values are different from daily-based values (normal for stocks), the pivot levels will also differ.", group="Dynamic Pivots")
kind = input.string(title="Type", defval="Fibonacci", options=[FIBONACCI, CAMARILLA, TRADITIONAL, PIVOTBOSS, VPR], group="Dynamic Pivots")
pivot_time_frame = input.string(title="Pivots Timeframe", defval=AUTO, options=[AUTO, DAILY, WEEKLY, MONTHLY, QUARTERLY, YEARLY, BIYEARLY, TRIYEARLY, QUINQUENNIALLY, DECENNIALLY], group="Dynamic Pivots")
position_labels = input.string("Right", "Historical Pivot Labels Position", options=["Left", "Right"], group="Dynamic Pivots")
look_back = input.int(title="Number of Pivots Back", defval=15, minval=1, maxval=5000, group="Dynamic Pivots")
line_width = input.int(title="Line Width", defval=1, minval=1, maxval=100, group="Dynamic Pivots")
//------------------------------------------------------------------------------
// STEP 3 - FIB PIVOTS LINES
// Functions

draw_label_vpr(_x, _y, _text, _xloc, _yloc, _color, _style, _textcolor, _size, _textalign, _tooltip) =>
    dlabel = label.new(x=_x, y=_y, text=_text, xloc=_xloc, yloc=_yloc, color=_color, style=_style, textcolor=_textcolor, size=_size,textalign=_textalign, tooltip=_tooltip)
    label.delete(dlabel[1])

//Inputs
show_fibpiv   = input(false   , "Show Extra Fibonacci Pivots?", inline="Show Fibonacci Pivots?",group="Extra Fib Pivot")
show_fibpiv_labels   = input(false   , "Show Extra Fibonacci Pivot Labels?", inline="Show Fibonacci Pivots?",group="Extra Fib Pivot")
tfselect = input.timeframe(title='Fib Pivot Time Frame', defval='D', options=['D', 'M', 'W'],group="Extra Fib Pivot")
rightShift = input.int(title='Pivot Label offset', defval=20, step=1,group="Extra Fib Pivot")

showR1 = input.bool(title='R1' , defval=false, inline='R12345', group='Extra Fib Pivot', tooltip='')
