    draw_label_vpr(bar_index[0] + cprLabelOffset, tTC, "M-TPP = " + str.tostring(tTC, '0.00'), xloc.bar_index, yloc.price, color.new(color.white, 0), label.style_none, color.new(color.white, 0), size.normal, text.align_left, "M-TPP = " + str.tostring(tTC, '0.00'))
    draw_label_vpr(bar_index[0] + cprLabelOffset, tBC, "M-BPP = " + str.tostring(tBC, '0.00'), xloc.bar_index, yloc.price, color.new(color.white, 0), label.style_none, color.new(color.white, 0), size.normal, text.align_left, "M-BPP = " + str.tostring(tBC, '0.00'))

if(showWeeklyCam and passlock)
    draw_label_vpr(bar_index[0] + weeklyCamOffset, weeklyCamr3, "SELL REVERSAL = " + str.tostring(weeklyCamr3, '0.00'), xloc.bar_index, yloc.price, color.new(color.orange, 0), label.style_none, color.new(color.orange, 0), size.normal, text.align_left, "SELL REVERSAL = " + str.tostring(weeklyCamr3, '0.00'))
    draw_label_vpr(bar_index[0] + weeklyCamOffset, weeklyCamr4, "BULLISH BO = " + str.tostring(weeklyCamr4, '0.00'), xloc.bar_index, yloc.price, color.new(color.orange, 0), label.style_none, color.new(color.orange, 0), size.normal, text.align_left, "BULLISH BO = " + str.tostring(weeklyCamr4, '0.00'))
    draw_label_vpr(bar_index[0] + weeklyCamOffset, weeklyCamr5, "BO TARGET = " + str.tostring(weeklyCamr5, '0.00'), xloc.bar_index, yloc.price, color.new(color.orange, 0), label.style_none, color.new(color.orange, 0), size.normal, text.align_left, "BO TARGET = " + str.tostring(weeklyCamr5, '0.00'))
    draw_label_vpr(bar_index[0] + weeklyCamOffset, th_d_w, "PWH = " + str.tostring(th_d_w, '0.00'), xloc.bar_index, yloc.price, color.new(color.orange, 0), label.style_none, color.new(color.orange, 0), size.normal, text.align_left, "PWH = " + str.tostring(th_d_w, '0.00'))

    draw_label_vpr(bar_index[0] + weeklyCamOffset, weeklyCams3, "BUY REVERSAL = " + str.tostring(weeklyCams3, '0.00'), xloc.bar_index, yloc.price, color.new(color.aqua, 0), label.style_none, color.new(color.aqua, 0), size.normal, text.align_left, "BUY REVERSAL = " + str.tostring(weeklyCams3, '0.00'))
    draw_label_vpr(bar_index[0] + weeklyCamOffset, weeklyCams4, "BEARISH BO = " + str.tostring(weeklyCams4, '0.00'), xloc.bar_index, yloc.price, color.new(color.aqua, 0), label.style_none, color.new(color.aqua, 0), size.normal, text.align_left, "BEARISH BO = " + str.tostring(weeklyCams4, '0.00'))
    draw_label_vpr(bar_index[0] + weeklyCamOffset, weeklyCams5, "BO TARGET = " + str.tostring(weeklyCams5, '0.00'), xloc.bar_index, yloc.price, color.new(color.aqua, 0), label.style_none, color.new(color.aqua, 0), size.normal, text.align_left, "BO TARGET = " + str.tostring(weeklyCams5, '0.00'))
    draw_label_vpr(bar_index[0] + weeklyCamOffset, tl_d_w, "PWL = " + str.tostring(tl_d_w, '0.00'), xloc.bar_index, yloc.price, color.new(color.aqua, 0), label.style_none, color.new(color.aqua, 0), size.normal, text.align_left, "PWL = " + str.tostring(tl_d_w, '0.00'))

//----------------------------------------------------------------------------------------------------
//MARKET STRUCTURE
//Description: Enhanced Zig Zag indicator that plot points on the chart whenever prices reverse by a percentage greater than a pre-chosen variable.

// Hull trend

plotHUL = input(title='Plot HULL Trend?', defval=false, group="Hull Trend")
tf = input.timeframe('10', title='Timeframe for HMA', options=['1', '5', '10', '15', '30', '60', '120', '240', '360', '720', 'D', 'W', 'Y'], group="Hull Trend")
hullsrc = input(hl2, group="Hull Trend")
length = input(24, title='Period', group="Hull Trend")
shift = input(0, title='Offset', group="Hull Trend")

hma3(_src, _length) =>
    p = length / 2
    ta.wma(ta.wma(close, p / 3) * 3 - ta.wma(close, p / 2) - ta.wma(close, p), p)

aa = request.security(syminfo.tickerid, tf, ta.hma(hullsrc, length)[shift])
bb = request.security(syminfo.tickerid, tf, hma3(hullsrc, length)[shift])
cc = bb > aa ? color.lime : color.red
p1 = plot(passlock and plotHUL ? aa : na, color=cc, linewidth=1, transp=75)
p2 = plot(passlock and plotHUL ? bb : na, color=cc, linewidth=1, transp=75)
fill(p1, p2, color=cc, transp=25)
crossdn = aa > bb and aa[1] < bb[1]
crossup = bb > aa and bb[1] < aa[1]
plotshape(showcross and crossdn and passlock ? aa : na, location=location.absolute, style=shape.labeldown, color=color.new(color.red, 0), size=size.tiny, text='Sell', textcolor=color.new(color.white, 0), offset=0)
plotshape(showcross and crossup and passlock ? aa : na, location=location.absolute, style=shape.labelup, color=color.new(color.green, 0), size=size.tiny, text='Buy', textcolor=color.new(color.white, 0), offset=0)
alertcondition(showcross and crossdn and passlock ? aa : na, title='hma long', message='hma: long ')
alertcondition(showcross and crossup and passlock ? aa : na, title='hma short', message='hma: short ')
//----------------------------------------------------------------------------------------------------
// Bollinger Bands
plotBoll = input(title='Plot Bollinger Bands?', defval=false, group="Bollinger Bands")
len = input(20, group="Bollinger Bands")
// Draw channel.
channelType = input.string(defval='Bollinger', title='Channel Type', options=['NONE', 'Donchian', 'Bollinger', 'Envelope'], group="Bollinger Bands")
channelLen = input.int(14, minval=1, title='Channel Length', group="Bollinger Bands")
envPer = input.float(4, title='Envelope %', minval=0, group="Bollinger Bands") / 100

getChannels(hullsrc, len) =>
    if channelType == 'Bollinger'
        ma = ta.ema(hullsrc, len)
        dev = ta.stdev(hullsrc, len)
        bbUp = ma + 2 * dev
        bbDown = ma - 2 * dev
        [bbUp, bbDown]
    else
        if channelType == 'Donchian'
            donUp = ta.highest(high[1], len)
            donDown = ta.lowest(low[1], len)
            [donUp, donDown]
        else
            if channelType == 'Envelope'
                ma = ta.ema(hullsrc, len)
                envUp = ma * (1 + envPer)
                envDown = ma * (1 - envPer)
                [envUp, envDown]
            else
                [na, na]

[upperchannel, lowerchannel] = getChannels(hullsrc, len)
u = plot(passlock and plotBoll ? upperchannel : na, linewidth=1, color=color.new(color.black, 0), title='Band High')
plot(passlock and plotBoll ? math.avg(upperchannel, lowerchannel) : na, linewidth=1, color=color.new(color.red, 0), title='Band Middle')
l = plot(passlock and plotBoll ? lowerchannel : na, linewidth=1, color=color.new(color.black, 0), title='Band Low')
fill(u, l, transp=90)
//----------------------------------------------------------------------------------------------------
// Coloured volume candles - VMA = Volume Moving Average
// Decipher : x > 1.5 VMA - Massive BUY/SELL | 0.5VMA =< x < 1.5VMA - Normal | x < 0.5VMA - Interest Drop

showVolCol = input(false, 'Enable Dynamic Volume Based Candle Color?', group="Volume Based Bar Color", tooltip='x > 1.5 VMA - Massive BUY/SELL | 0.5VMA =< x < 1.5VMA - Normal | x < 0.5VMA - Interest Drop')
lengthbar = input.int(13, 'Volume Candle Length', minval=1, group="Volume Based Bar Color")
volumeAverage = input.string("SMA" ,"Volume Moving Average", options=["SMA", "EMA", "SMMA (RMA)", "WMA", "VWMA", "HMA", "EHMA"],group="Volume Based Bar Color")

colu1  = input(color.lime, "High Volume Color  ", inline="High",group="Volume Based Bar Color")
cold1  = input(color.maroon, "", inline="High",group="Volume Based Bar Color")

colu2  = input(color.green, "Normal Volume Color", inline="Normal",group="Volume Based Bar Color")
cold2  = input(color.red, "", inline="Normal",group="Volume Based Bar Color")

colu3  = input(color.gray, "Low Volume Color   ", inline="Low",group="Volume Based Bar Color")
cold3  = input(color.gray, "", inline="Low",group="Volume Based Bar Color")

avrg = ma(volume, lengthbar, volumeAverage)

vold1 = volume > avrg * 1.5 and close < open
vold2 = volume >= avrg * 0.5 and volume <= avrg * 1.5 and close < open
vold3 = volume < avrg * 0.5 and close < open

volu1 = volume > avrg * 1.5 and close > open
volu2 = volume >= avrg * 0.5 and volume <= avrg * 1.5 and close > open
volu3 = volume < avrg * 0.5 and close > open

color = vold1 and showVolCol ? cold1 : vold2 and showVolCol ? cold2 : vold3 and showVolCol ? cold3 : volu1 and showVolCol ? colu1 : volu2 and showVolCol ? colu2 : volu3 and showVolCol ? colu3 : na

barcolor(color)



