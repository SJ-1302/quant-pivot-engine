//----------------------------------------------------------------------------------------------------
// ALL IN ONE CPR
//----------------------------------------------------------------------------------------------------
//Central Pivot Range - COnt'd from Line 387

showcross = input(false, 'Show Buy/Sell signal from Bollinger/Hull CO', group="Bollinger/Hull Crossover")

// Pivot Range
tP = (th_d + tl_d + tc_d) / 3
tTC = (th_d + tl_d) / 2
tBC = tP - tTC + tP

tP_w = (th_d_w + tl_d_w + tc_d_w) / 3
tTC_w = (th_d_w + tl_d_w) / 2
tBC_w = tP_w - tTC_w + tP_w

weeklyCampivot_range = th_d_w - tl_d_w
weeklyCamr1 = tc_d_w + weeklyCampivot_range * 1.1 / 12.0
weeklyCams1 = tc_d_w - weeklyCampivot_range * 1.1 / 12.0
weeklyCamr2 = tc_d_w + weeklyCampivot_range * 1.1 / 6.0
weeklyCams2 = tc_d_w - weeklyCampivot_range * 1.1 / 6.0
weeklyCamr3 = tc_d_w + weeklyCampivot_range * 1.1 / 4.0
weeklyCams3 = tc_d_w - weeklyCampivot_range * 1.1 / 4.0
weeklyCamr4 = tc_d_w + weeklyCampivot_range * 1.1 / 2.0
weeklyCams4 = tc_d_w - weeklyCampivot_range * 1.1 / 2.0
weeklyCamr5 = th_d_w / tl_d_w * tc_d_w
weeklyCams5 = 2 * tc_d_w - weeklyCamr5

weeklyCamR3Line = showWeeklyCam and passlock ? line.new(oTime, weeklyCamr3, cTime, weeklyCamr3, xloc=xloc.bar_time, color=color.orange,extend=extend.both) : na
weeklyCamR4Line = showWeeklyCam and passlock ? line.new(oTime, weeklyCamr4, cTime, weeklyCamr4, xloc=xloc.bar_time, color=color.orange,extend=extend.both) : na
weeklyCamR5Line = showWeeklyCam and passlock ? line.new(oTime, weeklyCamr5, cTime, weeklyCamr5, xloc=xloc.bar_time, color=color.orange,extend=extend.both) : na
weeklypdh = showWeeklyCam and passlock ? line.new(oTime, th_d_w, cTime, th_d_w, xloc=xloc.bar_time, color=color.orange,extend=extend.both) : na

weeklyCamS3Line = showWeeklyCam and passlock ? line.new(oTime, weeklyCams3, cTime, weeklyCams3, xloc=xloc.bar_time, color=color.aqua,extend=extend.both) : na
weeklyCamS4Line = showWeeklyCam and passlock ? line.new(oTime, weeklyCams4, cTime, weeklyCams4, xloc=xloc.bar_time, color=color.aqua,extend=extend.both) : na
weeklyCamS5Line = showWeeklyCam and passlock ? line.new(oTime, weeklyCams5, cTime, weeklyCams5, xloc=xloc.bar_time, color=color.aqua,extend=extend.both) : na
weeklypdl = showWeeklyCam and passlock ? line.new(oTime, tl_d_w, cTime, tl_d_w, xloc=xloc.bar_time, color=color.aqua,extend=extend.both) : na

weekly_tP_w = show_CPR_tomorrow and passlock ? line.new(oTime, tP_w, cTime, tP_w, xloc=xloc.bar_time, color=color.lime,extend=extend.right) : na
weekly_tTC_w = show_CPR_tomorrow and passlock ? line.new(oTime, tTC_w, cTime, tTC_w, xloc=xloc.bar_time, color=color.lime,extend=extend.right) : na
weekly_tBC_w = show_CPR_tomorrow and passlock ? line.new(oTime, tBC_w, cTime, tBC_w, xloc=xloc.bar_time, color=color.lime,extend=extend.right) : na

monthly_tP_w = show_cpr_monthly and passlock ? line.new(oTime, tP, cTime, tP, xloc=xloc.bar_time, color=color.white,extend=extend.right) : na
monthly_tTC_w = show_cpr_monthly and passlock ? line.new(oTime, tTC, cTime, tTC, xloc=xloc.bar_time, color=color.white,extend=extend.right) : na
monthly_tBC_w = show_cpr_monthly and passlock ? line.new(oTime, tBC, cTime, tBC, xloc=xloc.bar_time, color=color.white,extend=extend.right) : na

//weeklyCamOffset

if(show_CPR_tomorrow and passlock)
    draw_label_vpr(bar_index[0] + cprLabelOffset, tP_w, "W-PP = " + str.tostring(tP_w, '0.00'), xloc.bar_index, yloc.price, color.new(color.lime, 0), label.style_none, color.new(color.lime, 0), size.normal, text.align_left, "W-PP = " + str.tostring(tP_w, '0.00'))
    draw_label_vpr(bar_index[0] + cprLabelOffset, tTC_w, "W-TPP = " + str.tostring(tTC_w, '0.00'), xloc.bar_index, yloc.price, color.new(color.lime, 0), label.style_none, color.new(color.lime, 0), size.normal, text.align_left, "W-TPP = " + str.tostring(tTC_w, '0.00'))
    draw_label_vpr(bar_index[0] + cprLabelOffset, tBC_w, "W-BPP = " + str.tostring(tBC_w, '0.00'), xloc.bar_index, yloc.price, color.new(color.lime, 0), label.style_none, color.new(color.lime, 0), size.normal, text.align_left, "W-BPP = " + str.tostring(tBC_w, '0.00'))

