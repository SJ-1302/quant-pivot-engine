showS19 = input.bool(title='S19', defval=false, inline='S12345', group='Extra Fib Pivot', tooltip='')
showS20 = input.bool(title='S20', defval=false, inline='S12345', group='Extra Fib Pivot', tooltip='')
showS21 = input.bool(title='S21', defval=false, inline='S12345', group='Extra Fib Pivot', tooltip='')
showS22 = input.bool(title='S22', defval=false, inline='S12345', group='Extra Fib Pivot', tooltip='')
showS23 = input.bool(title='S23', defval=false, inline='S12345', group='Extra Fib Pivot', tooltip='')

fibonacci_levelr1 = 0.236
fibonacci_levelr2 = 0.382
fibonacci_levelr3 = 0.5
fibonacci_levelr4 = 0.618
fibonacci_levelr5 = 0.786
fibonacci_levelr6 = 1
fibonacci_levelr7 = 1.272
fibonacci_levelr8 = 1.414
fibonacci_levelr9 = 1.618
fibonacci_levelr10 = 2
fibonacci_levelr11 = 2.272
fibonacci_levelr12 = 2.414
fibonacci_levelr13 = 2.618
fibonacci_levelr14 = 3
fibonacci_levelr15 = 3.272
fibonacci_levelr16 = 3.414
fibonacci_levelr17 = 3.618
fibonacci_levelr18 = 4
fibonacci_levelr19 = 4.236
fibonacci_levelr20 = 4.272
fibonacci_levelr21 = 4.414
fibonacci_levelr22 = 4.618
fibonacci_levelr23 = 4.764

fibonacci_levels1 = 0.236
fibonacci_levels2 = 0.382
fibonacci_levels3 = 0.5
fibonacci_levels4 = 0.618
fibonacci_levels5 = 0.786
fibonacci_levels6 = 1
fibonacci_levels7 = 1.272
fibonacci_levels8 = 1.414
fibonacci_levels9 = 1.618
fibonacci_levels10 = 2
fibonacci_levels11 = 2.272
fibonacci_levels12 = 2.414
fibonacci_levels13 = 2.618
fibonacci_levels14 = 3
fibonacci_levels15 = 3.272
fibonacci_levels16 = 3.414
fibonacci_levels17 = 3.618
fibonacci_levels18 = 4
fibonacci_levels19 = 4.236
fibonacci_levels20 = 4.272
fibonacci_levels21 = 4.414
fibonacci_levels22 = 4.618
fibonacci_levels23 = 4.764

//------------------------------------------------------------------------------
//Calc
High = request.security(syminfo.ticker, tfselect, high[1], barmerge.gaps_off, barmerge.lookahead_on)
Low = request.security(syminfo.ticker, tfselect, low[1], barmerge.gaps_off, barmerge.lookahead_on)
Close = request.security(syminfo.ticker, tfselect, close[1], barmerge.gaps_off, barmerge.lookahead_on)
start = request.security(syminfo.ticker, tfselect, time, barmerge.gaps_off, barmerge.lookahead_on)
last = request.security(syminfo.ticker, tfselect, ta.valuewhen(barstate.islast, time, 0), barmerge.gaps_off, barmerge.lookahead_on)
newDay = ta.change(start)

// Compute Fibonacci Levels + CPR
lastDay = start >= last
pp = (High + Low + Close) / 3
//------------------------------------------------------------------------------
R1 = pp + (High - Low) * fibonacci_levelr1
R2 = pp + (High - Low) * fibonacci_levelr2
R3 = pp + (High - Low) * fibonacci_levelr3
R4 = pp + (High - Low) * fibonacci_levelr4
R5 = pp + (High - Low) * fibonacci_levelr5
R6 = pp + (High - Low) * fibonacci_levelr6
R7 = pp + (High - Low) * fibonacci_levelr7
R8 = pp + (High - Low) * fibonacci_levelr8
R9 = pp + (High - Low) * fibonacci_levelr9
R10 = pp + (High - Low) * fibonacci_levelr10
R11 = pp + (High - Low) * fibonacci_levelr11
R12 = pp + (High - Low) * fibonacci_levelr12
R13 = pp + (High - Low) * fibonacci_levelr13
R14 = pp + (High - Low) * fibonacci_levelr14
R15 = pp + (High - Low) * fibonacci_levelr15
R16 = pp + (High - Low) * fibonacci_levelr16
R17 = pp + (High - Low) * fibonacci_levelr17
R18 = pp + (High - Low) * fibonacci_levelr18
R19 = pp + (High - Low) * fibonacci_levelr19
R20 = pp + (High - Low) * fibonacci_levelr20
R21 = pp + (High - Low) * fibonacci_levelr21
R22 = pp + (High - Low) * fibonacci_levelr22
R23 = pp + (High - Low) * fibonacci_levelr23

S1 = pp - (High - Low) * fibonacci_levels1
S2 = pp - (High - Low) * fibonacci_levels2
S3 = pp - (High - Low) * fibonacci_levels3
S4 = pp - (High - Low) * fibonacci_levels4
S5 = pp - (High - Low) * fibonacci_levels5
